# Copia este archivo a .env.local y completa con los datos de tu proyecto Sanity
# (los encuentras en https://sanity.io/manage dentro de tu proyecto)

NEXT_PUBLIC_SANITY_PROJECT_ID=tu_project_id
NEXT_PUBLIC_SANITY_DATASET=production
NEXT_PUBLIC_SANITY_API_VERSION=2024-01-01

# Token con permiso de escritura (Editor) para guardar los mensajes del
# formulario de contacto como documentos "contactSubmission".
# Créalo en https://sanity.io/manage dentro de tu proyecto → API → Tokens.
SANITY_API_WRITE_TOKEN=

# API key de Anthropic para el asistente de chat (https://console.anthropic.com/)
ANTHROPIC_API_KEY=

# Secreto compartido para el webhook de revalidación on-demand.
# Configura un webhook en sanity.io/manage → API → Webhooks apuntando a
# https://tudominio.com/api/revalidate?secret=ESTE_VALOR (dispara en
# Create/Update/Delete) para que los cambios se reflejen al instante,
# sin esperar el revalidate de 60s.
SANITY_REVALIDATE_SECRET=

# Envío de correo del formulario de contacto vía SMTP de iCloud.
# ICLOUD_EMAIL: tu dirección @icloud.com / @me.com
# ICLOUD_APP_PASSWORD: contraseña de aplicación generada en appleid.apple.com
#   (Seguridad → Contraseñas específicas de apps) — no uses tu contraseña normal.
# CONTACT_EMAIL_TO: dirección que recibe los mensajes del formulario.
ICLOUD_EMAIL=
ICLOUD_APP_PASSWORD=
CONTACT_EMAIL_TO=
